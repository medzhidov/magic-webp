# Source files (not needed in npm package)
src-c/
src-js/*
!src-js/worker.ts
demo/
tests/
scripts/

# Build files (but keep pkg/ output)
build/
test-output/
emsdk/
libwebp/
node_modules/

# Explicitly include pkg/ files (override .gitignore)
!pkg/*.wasm
!pkg/*.mjs
!pkg/*.d.ts
!pkg/*.js

# Config files
CMakeLists.txt
tsconfig.json
vitest.config.ts
*.ps1
.gitignore
.npmignore

# Documentation (keep only README and LICENSE)
*.md
!README.md

# Development
.vscode/
.idea/
*.log

