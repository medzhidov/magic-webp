{
  "name": "magic-webp",
  "version": "1.0.8",
  "description": "Convert PNG/JPEG/GIF to WebP and process images (crop, resize) in the browser using WebAssembly. Supports animated GIFs.",
  "keywords": [
    "webp",
    "image",
    "convert",
    "resize",
    "crop",
    "png",
    "jpeg",
    "gif",
    "wasm",
    "webassembly",
    "animated",
    "browser",
    "compression",
    "optimization"
  ],
  "author": "medzhidov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medzhidov/magic-webp.git"
  },
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./worker": {
      "types": "./lib/worker.d.ts",
      "import": "./lib/worker.js"
    }
  },
  "files": [
    "lib/**/*",
    "pkg/*.mjs",
    "pkg/*.wasm",
    "pkg/*.d.ts",
    "pkg/package.json",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build:wasm": "node -e \"process.platform === 'win32' ? require('child_process').execSync('powershell -ExecutionPolicy Bypass -File build.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash build.sh', {stdio: 'inherit'})\"",
    "build:wasm:dev": "node -e \"process.platform === 'win32' ? require('child_process').execSync('powershell -ExecutionPolicy Bypass -File build.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash build.sh', {stdio: 'inherit'})\"",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "pnpm run build:wasm && pnpm run build:ts",
    "demo": "pnpm run build:wasm && pnpm run demo:watch",
    "demo:watch": "vite demo",
    "demo:build": "pnpm run build:wasm && vite build demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:native": "powershell -ExecutionPolicy Bypass -File test-native.ps1",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.8.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^4.0.18"
  },
  "directories": {
    "test": "tests"
  },
  "bugs": {
    "url": "https://github.com/medzhidov/magic-webp/issues"
  },
  "homepage": "https://github.com/medzhidov/magic-webp#readme"
}
